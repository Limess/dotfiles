[alias]
        c = commit -am
        up = pull
        p = push
        s = status -s
        sclone = clone --depth=1
        co = checkout
        df = diff --color --color-words --abbrev
        lg = log --color --graph --pretty=format:'%Cred%h%Creset -%C(yellow)%d%Creset %s %Cgreen(%cr) %C(bold blue)<%an>%Creset' --abbrev-commit --

        # Show the diff between the latest commit and the current state
        d = !"git diff-index --quiet HEAD -- || clear; git --no-pager diff --patch-with-stat"

        reup = rebase-update # depot_tools specific
        fpush = push --force-with-lease
[user]
    email = "{{ .email }}"
    name = "{{ .name }}"
[credential]
        helper = store
[core]
        # https://news.ycombinator.com/item?id=11388479
        untrackedCache = true
	excludesfile = ~/.gitignore
        attributesfile = ~/.gitattributes
	autocrlf = false
	eol = lf
[pager]
	diff = delta
	show = delta
	log = delta
	reflog = delta
[interactive]
	diffFilter = delta --color-only
[delta]
	navigate = true
	side-by-side = true
	line-numbers = true
	syntax-theme = Dracula
[color]
        ui = always
[color "branch"]
        current = yellow reverse
        local = yellow
        remote = green
[color "status"]
        added = green
        changed = yellow
        untracked = cyan
[diff]
	colorMoved = dimmed-zebra
	external = difft
[merge]
        # git mergetool
	# tool = opendiff
        # present 3 way conflict editor
	# conflictstyle = diff3
# rewrites of repo paths
[url "git@github.com:"]
        insteadOf = "gh:"
        insteadOf = "git://github.com"
        pushInsteadOf = "github:"
        pushInsteadOf = "git://github.com/"
        pushInsteadOf = "https://github.com/"
[url "git@gist.github.com:"]
        insteadOf = "gst:"
        pushInsteadOf = "gist:"
        pushInsteadOf = "git://gist.github.com/"
        pushInsteadOf = "https://gist.github.com/"
[help]
        # correct typos
        autocorrect = 1
[fetch]
	prune = true
[push]
       # push easily. http://stackoverflow.com/a/23918418/89484
        default = current
[branch]
        # when a new branch is created, setup git pull to rebase rather than merge
        autosetuprebase = always
[rebase]
        # squash fixup commits automatically when rebasing interactively
	autosquash = true
[status]
        # show all untracked files rather than just the directory containing them
        showUntrackedFiles = all
[tag]
        # Sort tags as version numbers whenever applicable, so 1.10.2 is AFTER 1.2.0.
        sort = version:refname
[versionsort]
        prereleaseSuffix = -pre
        prereleaseSuffix = .pre
        prereleaseSuffix = -beta
        prereleaseSuffix = .beta
        prereleaseSuffix = -rc
        prereleaseSuffix = .rc
[init]
	defaultBranch = main
        # templatedir = ~/.git_template
[filter "lfs"]
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
        required = true
	process = git-lfs filter-process
[http]
[submodule]
	stickyRecursiveClone = true
[pull]
	rebase = true
[remote "origin"]
	prune = true
