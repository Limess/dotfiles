{
  "env": {
    "NO_COLOR": "1",
    "AWS_JAVA_V1_DISABLE_DEPRECATION_ANNOUNCEMENT": "true"
  },
  "permissions": {
    "allow": [
      "mcp__serena__*",
      "Bash(git diff *)",
      "Bash(git -C * diff *)",
      "Bash(git log *)",
      "Bash(git -C * log *)",
      "Bash(git status *)",
      "Bash(git -C * status *)",
      "Bash(git show *)",
      "Bash(git -C * show *)",
      "Bash(git branch *)",
      "Bash(git -C * branch *)",
      "Bash(git tag *)",
      "Bash(git -C * tag *)",
      "Bash(git stash list *)",
      "Bash(git -C * stash list *)",
      "Bash(git rev-parse *)",
      "Bash(git -C * rev-parse *)",
      "Bash(git blame *)",
      "Bash(git -C * blame *)",
      "Bash(git shortlog *)",
      "Bash(git -C * shortlog *)",
      "Bash(git checkout *)",
      "Bash(git -C checkout *)",
      "Bash(git add *)",
      "Bash(git -C add *)",
      "Bash(git pull *)",
      "Bash(git -C pull *)",
      "Bash(ls *)",
      "Bash(pwd)",
      "Bash(wc *)",
      "Bash(which *)",
      "Bash(whoami)",
      "Bash(cat *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(find *)",
      "Bash(tree *)",
      "Bash(file *)",
      "Bash(du *)",
      "Bash(df *)",
      "Bash(date *)",
      "Bash(uname *)",
      "Bash(aws sts get-caller-identity*)"
    ],
    "deny": [
      "Read(./**/.env*)",
      "Read(./**/profiles.clj)",
      "Bash(cat *.env*)",
      "Bash(head *.env*)",
      "Bash(tail *.env*)",
      "Bash(cat *profiles.clj*)",
      "Bash(head *profiles.clj*)",
      "Bash(tail *profiles.clj*)",
      "Bash(aws *)",
      "Bash(ssh *)",
      "Bash(cat */.aws/*)",
      "Bash(head */.aws/*)",
      "Bash(tail */.aws/*)",
      "Bash(cat */.ssh/*)",
      "Bash(head */.ssh/*)",
      "Bash(tail */.ssh/*)",
      "Read(~/.aws/*)",
      "Read(~/.ssh/*)",
      "mcp__serena__write_memory",
      "mcp__serena__read_memory",
      "mcp__serena__list_memories",
      "mcp__serena__delete_memory",
      "mcp__serena__rename_memory",
      "mcp__serena__edit_memory"
    ]
  },
  "model": "opus",
  "hooks": {
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "osascript -e 'display notification \"Claude Code needs your attention\" with title \"Claude Code\"'"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "$HOME/.claude/hooks/statusline.sh"
  },
  "enabledPlugins": {
    "superpowers@claude-plugins-official": false,
    "claude-code-setup@claude-plugins-official": true,
    "claude-md-management@claude-plugins-official": true
  },
  "voiceEnabled": true
}
